{
  "name": "palladium",
  "version": "1.0.0",
  "description": "Ultimate downloader — TikTok and more, no watermark",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "dev": "electron . --inspect",
    "build:mac": "node scripts/prepare-bins.js && electron-builder --mac",
    "build:win": "node scripts/prepare-bins.js && electron-builder --win",
    "build:linux": "node scripts/prepare-bins.js && electron-builder --linux"
  },
  "keywords": [],
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "multer": "^2.1.1",
    "yt-dlp-wrap": "^2.3.12"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.palladium.app",
    "productName": "Palladium",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/ffmpeg",
      "**/node_modules/ffmpeg-static/ffmpeg.exe"
    ],
    "files": [
      "electron/**/*",
      "static/**/*",
      "server.js",
      "node_modules/**/*",
      "!node_modules/.cache",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "bin/",
        "to": "bin/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist"
    },
    "dmg": {
      "title": "Palladium",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  }
}
